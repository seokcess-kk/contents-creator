# web/frontend/.env.local 템플릿 — 복사 후 실제 값 채우기
# 커밋 금지 (Next.js 는 .env.local 을 기본으로 .gitignore 처리)

# === 서버사이드 전용 (브라우저 노출 X) ===

# 백엔드 API origin. Next rewrites + src/proxy.ts 가 사용.
# NEXT_PUBLIC_ 접두어가 없으므로 번들에 포함되지 않는다.
BACKEND_API_URL=http://localhost:8000

# 백엔드 ADMIN_API_KEY 와 **동일** 값. src/proxy.ts 가 `/api/*` 요청 헤더에
# X-API-Key 로 주입한다. 브라우저는 이 값을 절대 볼 수 없다.
API_KEY=

# === 클라이언트 노출 (origin 만, 키 X) ===

# WebSocket 직접 연결용 origin. Next proxy 는 WS 업그레이드를 처리하지 못하므로
# 브라우저가 외부 origin 에 직접 붙는다. admin key 는 URL 에 실리지 않고
# jobId 바운드 단명 서명 토큰(`/api/jobs/{id}/ws-token`) 만 쓰인다.
NEXT_PUBLIC_WS_URL=http://localhost:8000
