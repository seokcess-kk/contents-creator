# web/frontend/.env.local 템플릿 — 복사 후 실제 값 채우기
# 커밋 금지 (Next.js 는 .env.local 을 기본으로 .gitignore 처리)

# 백엔드 API 주소 (로컬 개발은 기본값 사용)
NEXT_PUBLIC_API_URL=http://localhost:8000

# 백엔드 ADMIN_API_KEY 와 동일 값. 미설정 시 인증 헤더 미전송 (백엔드 dev 모드일 때만 동작).
# 주의: NEXT_PUBLIC_ 접두어 변수는 브라우저 번들에 포함되어 F12 로 노출된다.
# 내부 1~3명 사용 전제이며, 외부 공개 시 Route Handler 서버사이드 프록시로 전환 필요.
NEXT_PUBLIC_API_KEY=
