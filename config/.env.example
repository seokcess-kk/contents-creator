# config/.env 템플릿 — 복사 후 실제 키 채우기
# 커밋 금지. .gitignore에 config/.env 등록되어 있음.

# Bright Data (Web Unlocker 단일 zone)
# SERP 수집·본문 폴백·keyword_difficulty·ranking 공용. 본문 fetcher 를 insane 으로
# 써도 폴백용으로 여전히 필수 (아래 CRAWLER_BODY_FETCHER 참조).
BRIGHT_DATA_API_KEY=
BRIGHT_DATA_WEB_UNLOCKER_ZONE=

# 본문 수집 fetcher 라우팅 (하이브리드 insane + Bright Data 폴백)
# default insane — 본문([2])만 vendor/insane_search(curl-only) 우선 + 실패 시 Bright
# Data 자동 폴백. "brightdata" 로 두면 Bright Data 단독(롤백 밸브). SERP·
# keyword_difficulty 는 아래 CRAWLER_SERP_FETCHER 로 별도 라우팅(ranking 은 아직 Bright Data).
# CRAWLER_BODY_FETCHER=insane        # insane | brightdata
# INSANE_CONCURRENT_LIMIT=3          # insane 동시 호출 한도 (단일 IP 보수적)
# INSANE_TIMEOUT_SECONDS=30          # insane fetch 요청 타임아웃 (초)

# SERP·난이도 수집 fetcher 라우팅 (PR-S2, 하이브리드 insane desktop+#main_pack + 폴백)
# default insane — 분석 트랙 SERP(통합검색/블로그탭) + keyword_difficulty 난이도 SERP 를
# insane(curl-only) 우선 수집 + 실패/challenge 시 Bright Data 자동 폴백(무손실).
# "brightdata" 로 두면 Bright Data 단독(롤백 밸브). ranking 은 이 값과 무관(별도 확장 예정).
# CRAWLER_SERP_FETCHER=insane        # insane | brightdata

# Anthropic Claude
ANTHROPIC_API_KEY=

# Google Gen AI (Gemini Image)
GEMINI_API_KEY=

# Supabase
SUPABASE_URL=
SUPABASE_KEY=

# 웹 API 인증 (X-API-Key 헤더)
ADMIN_API_KEY=

# 웹 UI
CORS_ORIGINS=http://localhost:3000

# Job 제어
JOB_TIMEOUT_SECONDS=3600

# Title Validator (domain/generation/title_validator.py)
# 의료법 위반 시 hard fail (재생성 트리거) 여부. default false → logger.warning 만.
# 의료 외 도메인 false positive 방지 위해 default off.
TITLE_VALIDATOR_STRICT_COMPLIANCE=false

# Polish Pack P4: 형태소 매칭 임계값 (recall = keyword 명사 set 크기 분모).
# default 0.7 — keyword 명사 70% 이상이 title 명사에 포함되면 매칭 (kiwipiepy 사용).
# 운영 데이터 누적 후 조정 (false positive vs false negative trade-off).
TITLE_VALIDATOR_MORPHEME_THRESHOLD=0.7

# ────────────────────────────────────────────────────────────────────────────
# Phase J1.2 운영 권장값 — 메모리 절감 + BrightData 4xx 회피
# ────────────────────────────────────────────────────────────────────────────
# 2026-05-08 운영 사고 (백엔드 컨테이너 재시작으로 in-memory job 휘발) 분석 결과
# Render starter plan 512MB RAM 에서 Gemini base64 + Playwright 메모리 피크가
# OOM 트리거. 아래 3개 변수를 운영 환경에서 명시 하향 + Standard plan 업그레이드
# 권장. local 개발에서는 default 그대로 사용해도 무방.
#
# IMAGE_PARALLEL_WORKERS=2          # default 5 — Gemini 병렬 base64 메모리 절감
# BRIGHTDATA_CONCURRENT_LIMIT=3     # default 5 — 단일+배치 합산 4xx 회피
# BATCH_MAX_WORKERS=1               # default 2 — 배치 worker pool 축소

# ────────────────────────────────────────────────────────────────────────────
# Phase J2 — Job 상태 Supabase 영속화 (feature flag rollout)
# ────────────────────────────────────────────────────────────────────────────
# default false → 기존 in-memory JobManager 만 동작. true 로 전환하면 jobs +
# progress_events 테이블에 write-through. config/schema.sql 의 jobs / progress_events
# 테이블 마이그레이션이 선행되어야 한다 (Supabase Dashboard SQL Editor 에 schema.sql
# 전체 1회 붙여넣기. idempotent).
#
# rollout 권장: PR2 까지 false 유지 → staging 에서 true 로 1주 관찰 → 운영 적용
# graceful degrade: Supabase 호출 실패 시 logger.warning 흡수 + in-memory only 강등
#
# JOB_PERSISTENCE_ENABLED=false      # default false. true 시 jobs 테이블 write/read
# JOB_HEARTBEAT_SECONDS=30           # running job heartbeat 갱신 주기 (초)
# JOB_ORPHANED_GRACE_SECONDS=300     # last_heartbeat 만료 grace (초). 첫 24h 는 900 (15분)
                                      # 보수 권장, 운영 안정 후 300 (5분) 단축
# JOB_SWEEP_INTERVAL_SECONDS=300     # orphaned sweep 주기 (초). flag on 시 lifespan
                                      # 에서 asyncio.create_task. 빠른 검출 필요 시 60s 까지

# ────────────────────────────────────────────────────────────────────────────
# Phase AP — 자동 발행 (2026-05-10)
# ────────────────────────────────────────────────────────────────────────────
# 차용: seokcess-kk/auto-publishing@c64b5e7 (MIT, MoonbirdThinker).
# default false — 자산 위험 가장 높은 영역이라 강제 opt-in.
# PoC (Phase AP-A): 단일 채널 평문 발행. 사용 전 schema.sql 의 publishing_attempts
# 테이블 마이그레이션 선행 필요.

# PUBLISHING_ENABLED=false           # default false. true 시 NaverBlogPublisher 활성
# NAVER_USERNAME=                    # RSA 폴백 로그인용. CDP 우선이면 미설정 가능
# NAVER_PASSWORD=                    # RSA 폴백 로그인용
# NAVER_CHROME_PROFILE=Profile 2     # CDP 로그인 사용 Chrome 프로필명. 5채널 시 채널별 오버라이드
# CHROME_PATH=                       # chrome.exe 절대경로. 미설정 시 OS 자동 탐지
# MIN_PUBLISH_INTERVAL_MINUTES=30    # 동일 채널 직전 발행에서 최소 대기 (분). LRU 가드
# BLOCK_MEDICAL_AUTO_PUBLISH=false   # 의료 카테고리 자동 발행 차단. 안전망
