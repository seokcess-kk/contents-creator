# config/.env 템플릿 — 복사 후 실제 키 채우기
# 커밋 금지. .gitignore에 config/.env 등록되어 있음.

# Bright Data (Web Unlocker 단일 zone)
BRIGHT_DATA_API_KEY=
BRIGHT_DATA_WEB_UNLOCKER_ZONE=

# Anthropic Claude
ANTHROPIC_API_KEY=

# Google Gen AI (Gemini Image)
GEMINI_API_KEY=

# Supabase
SUPABASE_URL=
SUPABASE_KEY=

# 웹 API 인증 (X-API-Key 헤더)
ADMIN_API_KEY=

# 웹 UI
CORS_ORIGINS=http://localhost:3000

# Job 제어
JOB_TIMEOUT_SECONDS=3600

# Title Validator (domain/generation/title_validator.py)
# 의료법 위반 시 hard fail (재생성 트리거) 여부. default false → logger.warning 만.
# 의료 외 도메인 false positive 방지 위해 default off.
TITLE_VALIDATOR_STRICT_COMPLIANCE=false

# Polish Pack P4: 형태소 매칭 임계값 (recall = keyword 명사 set 크기 분모).
# default 0.7 — keyword 명사 70% 이상이 title 명사에 포함되면 매칭 (kiwipiepy 사용).
# 운영 데이터 누적 후 조정 (false positive vs false negative trade-off).
TITLE_VALIDATOR_MORPHEME_THRESHOLD=0.7
